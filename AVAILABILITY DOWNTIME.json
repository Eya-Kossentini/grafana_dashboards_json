          "rawQuery": true,
          "rawSql": "SELECT \r\n    m.station_name AS \"Station\",\r\n    ROUND(m.mtbf_hours::numeric, 2) AS \"MTBF (h)\",\r\n    ROUND(t.mttr_hours::numeric, 2) AS \"MTTR (h)\",\r\n    ROUND((m.mtbf_hours / NULLIF(t.mttr_hours, 0))::numeric, 1) AS \"Reliability Ratio\"\r\nFROM public.mtbf_kpi m\r\nLEFT JOIN public.mttr_kpi t ON m.station_id = t.station_id\r\nWHERE m.station_name IS NOT NULL\r\nORDER BY (m.mtbf_hours / NULLIF(t.mttr_hours, 0)) DESC;",
