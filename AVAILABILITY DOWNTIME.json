        {
          "dataset": "postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ranked AS (\r\n    SELECT\r\n        downtime_type,\r\n        SUM(downtime_hours) AS total_hours\r\n    FROM public.downtime_by_station_kpi\r\n    WHERE ('${station:csv}' = 'All' OR station_name IN (${station:sqlstring}))\r\n      AND $__timeFilter(production_day)\r\n      AND downtime_type NOT IN ('Running', 'Micro Stop')\r\n    GROUP BY downtime_type\r\n    ORDER BY total_hours DESC\r\n    LIMIT 1\r\n)\r\nSELECT\r\n    CONCAT(\r\n        '🚨 Main issue: ',\r\n        downtime_type,\r\n        ' — ',\r\n        ROUND(total_hours::numeric, 1),\r\n        ' h (',\r\n        ROUND(total_hours::numeric * 60, 0),\r\n        ' min)'\r\n    ) AS alert\r\nFROM ranked;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
