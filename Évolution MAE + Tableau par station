          "rawSql": "SELECT\r\n    station_name                                            AS \"Station\",\r\n    ROUND(defect_rate_pct::numeric, 2)            AS \"Réel J (%)\",\r\n    ROUND(ma_forecast::numeric, 2)                AS \"Prévision MA (%)\",\r\n    ROUND(es_forecast::numeric, 2)                AS \"Prévision ES (%)\",\r\n    ROUND((ma_forecast - defect_rate_pct)::numeric, 2) AS \"Δ MA\",\r\n    ROUND((es_forecast - defect_rate_pct)::numeric, 2) AS \"Δ ES\",\r\n    ROUND(ABS(ma_error)::numeric, 3)              AS \"MAE (MA)\",\r\n    ROUND(ABS(es_error)::numeric, 3)              AS \"MAE (ES)\",\r\n    CASE\r\n        WHEN COALESCE(es_forecast, ma_forecast) > 8.73 THEN '🔴 Au-dessus seuil'\r\n        WHEN COALESCE(es_forecast, ma_forecast) > 8.16 THEN '🟡 Zone Q3'\r\n        ELSE '🟢 Normal'\r\n    END                                                     AS \"Statut J+1\"\r\nFROM forecast_results\r\nWHERE production_day = (\r\n    SELECT MAX(production_day) FROM forecast_results\r\n)\r\n    AND station_name IN (${station:sqlstring})\r\nORDER BY COALESCE(es_forecast, ma_forecast) DESC NULLS LAST;",
