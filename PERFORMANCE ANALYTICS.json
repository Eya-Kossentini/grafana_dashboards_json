        {
          "dataset": "postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \r\n    station_name AS \"Station\",\r\n    ROUND(AVG(performance_pct)::numeric, 1) AS \"Performance %\",\r\n    ROUND(SUM(run_time_hours)::numeric, 0) AS \"Run Time (h)\",\r\n    ROUND(SUM(micro_stop_hours)::numeric, 0) AS \"Micro Stop (h)\",\r\n    CASE\r\n        WHEN AVG(performance_pct) >= 85 THEN '✅ Excellent'\r\n        WHEN AVG(performance_pct) >= 70 THEN '🟢 Good'\r\n        WHEN AVG(performance_pct) >= 60 THEN '🟡 Acceptable'\r\n        ELSE '🔴 Critical'\r\n    END AS \"Status\"\r\nFROM public.performance_kpi\r\nGROUP BY station_name\r\nORDER BY AVG(performance_pct) DESC;",
