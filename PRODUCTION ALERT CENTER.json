      "targets": [
        {
          "dataset": "postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    d.station_name,\r\n\r\n    MAX(d.downtime_minutes) AS downtime_minutes,\r\n    MAX(q.defect_rate_pct) AS defect_rate_pct,\r\n    AVG(o.oee_pct) AS oee_pct,\r\n\r\n    CASE\r\n        WHEN MAX(d.downtime_minutes) > 120 THEN '🔴 Critical Downtime'\r\n        WHEN MAX(q.defect_rate_pct) > 8 THEN '🟠 High Defect Rate'\r\n        WHEN AVG(o.oee_pct) < 60 THEN '🟡 Low OEE'\r\n        ELSE '🟢 Normal'\r\n    END AS detected_issue,\r\n\r\n    CASE\r\n        WHEN MAX(d.downtime_minutes) > 120 THEN 'Schedule urgent maintenance inspection'\r\n        WHEN MAX(q.defect_rate_pct) > 8 THEN 'Inspect calibration and production quality'\r\n        WHEN AVG(o.oee_pct) < 60 THEN 'Review production flow efficiency'\r\n        ELSE 'No action required'\r\n    END AS ai_recommendation\r\n\r\nFROM public.downtime_by_station_kpi d\r\n\r\nLEFT JOIN public.defect_rate_kpi q\r\n    ON d.station_name = q.station_name\r\n\r\nLEFT JOIN public.oee_kpi o\r\n    ON d.station_name = o.station_name\r\n\r\nWHERE d.station_name = '${station}'\r\n\r\nGROUP BY d.station_name;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
