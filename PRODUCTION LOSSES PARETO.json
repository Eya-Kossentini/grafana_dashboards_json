      "targets": [
        {
          "dataset": "postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH agg AS (\r\n  SELECT loss_type, sum(loss_hours) AS h\r\n  FROM public.pareto_losses_kpi\r\n  WHERE $__timeFilter(production_day)\r\n    AND loss_type IN (${loss_type:sqlstring})\r\n    AND station_name LIKE (${station:sqlstring})\r\n  GROUP BY loss_type\r\n),\r\ncalc AS (\r\n  SELECT loss_type, h,\r\n    row_number() OVER (ORDER BY h DESC) AS rang,\r\n    sum(h) OVER (ORDER BY h DESC)        AS cum,\r\n    sum(h) OVER ()                       AS total\r\n  FROM agg\r\n)\r\nSELECT rang, loss_type,\r\n  round(h,2)                               AS heures,\r\n  round(100.0*h/nullif(total,0),1)         AS pct,\r\n  round(100.0*cum/nullif(total,0),1)       AS cumul_pct,\r\n  CASE WHEN 100.0*cum/nullif(total,0) <= 80\r\n       THEN 'Vital few (80%)' ELSE 'Useful many' END AS classe_pareto\r\nFROM calc ORDER BY rang;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
